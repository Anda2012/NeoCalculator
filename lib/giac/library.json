{
  "name": "giac",
  "version": "1.9.0",
  "description": "Giac CAS engine for NumOS",
  "build": {
    "flags": [
      "-DGIAC_KHICAS",
      "-DNO_GUI",
      "-DGIAC_GENERIC",
      "-DEMBEDDED",
      "-DUMAP",
      "-fexceptions",
      "-Isrc"
    ],
    "srcFilter": [
      "+<src/*.cpp>",
      "+<src/*.c>",
      "-<src/kdisplay*>",
      "-<src/k_*.cpp>",
      "-<src/fx*.cpp>",
      "-<src/ti*.cpp>",
      "-<src/Xcas*>",
      "-<src/Fl_*>",
      "-<src/Graph*>",
      "-<src/hist*>",
      "-<src/test.cpp>"
    ]
  },
  "dependencies": {
    "libtommath": "*"
  }
}